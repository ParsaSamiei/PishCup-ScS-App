# Neon / Vercel Postgres connection string (required for local API)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Login credentials (required — without AUTH_PASSWORD the API rejects all requests)
AUTH_USERNAME=admin
AUTH_PASSWORD=choose-a-strong-password
# Optional: separate secret for signing tokens (defaults to AUTH_PASSWORD)
# AUTH_SECRET=another-long-random-string
